---
import TagPill from './TagPill.astro';
import { CATEGORY_BY_SLUG } from '../data/categories';
import type { CategorySlug } from '../data/categories';

export interface Props {
  slug: string;
  name: string;
  category: CategorySlug;
  subcategories: string[];
  chains: string[];
  logo: string | null | undefined;
}
const { slug, name, category, subcategories, chains, logo } = Astro.props;
const categoryName = CATEGORY_BY_SLUG[category]?.name ?? category;
---
<a
  href={`/protocols/${slug}/`}
  class="group flex flex-col gap-3 rounded-lg border border-ink-200 bg-white p-4 !text-ink-900 transition hover:border-accent hover:!text-ink-900 hover:shadow-sm dark:border-ink-700 dark:bg-ink-800 dark:!text-ink-100"
>
  <div class="flex items-center gap-3">
    {logo ? (
      <img src={logo} alt={name} class="h-10 w-10 rounded-full bg-ink-100 object-cover dark:bg-ink-700" loading="lazy" decoding="async" onerror="this.style.display='none'" />
    ) : (
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-ink-100 text-sm font-semibold text-ink-500 dark:bg-ink-700 dark:text-ink-400">
        {name.slice(0, 2).toUpperCase()}
      </div>
    )}
    <div class="min-w-0">
      <div class="truncate text-base font-semibold group-hover:text-accent">{name}</div>
      <div class="text-xs text-ink-500 dark:text-ink-400">{categoryName}</div>
    </div>
  </div>
  <div class="flex flex-wrap gap-1.5">
    {subcategories.slice(0, 2).map((s) => <TagPill variant="accent">{s}</TagPill>)}
    {chains.slice(0, 3).map((c) => <TagPill>{c}</TagPill>)}
    {chains.length > 3 && <TagPill>+{chains.length - 3}</TagPill>}
  </div>
</a>
