---
export interface Props {
  variant?: 'neutral' | 'accent';
  href?: string;
  title?: string;
}
const { variant = 'neutral', href, title } = Astro.props;
const cls = variant === 'accent' ? 'pill-accent' : 'pill-neutral';
---
{href ? (
  <a href={href} class={cls} title={title}><slot /></a>
) : (
  <span class={cls} title={title}><slot /></span>
)}
