---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;       // path or absolute URL; defaults to /og.png
  ogType?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const {
  title,
  description = 'An open-source directory of DeFi protocols.',
  ogImage = '/og.png',
  ogType = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;
const fullTitle = title ? `${title} — Dapp DeFi` : 'Dapp DeFi — the open directory of DeFi protocols';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://dappdefi.com').toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://dappdefi.com').toString();
const ldArr = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:site_name" content="Dapp DeFi" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* RSS feed discovery */}
    <link rel="alternate" type="application/rss+xml" title="Dapp DeFi — recently added protocols" href="/rss.xml" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {ldArr.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="border-b border-ink-200 bg-white/80 backdrop-blur dark:border-ink-700 dark:bg-ink-900/80">
      <div class="container-page flex items-center justify-between gap-6 py-4">
        <a href="/" class="text-lg font-semibold !text-ink-900 hover:!text-accent dark:!text-ink-100">
          <span class="text-accent">∆</span> Dapp DeFi
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/categories/lending" class="text-ink-600 hover:text-accent dark:text-ink-300">Categories</a>
          <a href="/compare/" class="text-ink-600 hover:text-accent dark:text-ink-300">Compare</a>
          <a href="https://github.com/vinniejames/dappdefi" target="_blank" rel="noopener" class="text-ink-600 hover:text-accent dark:text-ink-300">GitHub</a>
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-ink-200 dark:border-ink-700">
      <div class="container-page flex flex-col gap-2 py-6 text-sm text-ink-500 sm:flex-row sm:justify-between">
        <span>Open-source DeFi directory. MIT licensed.</span>
        <span>
          <a href="https://github.com/vinniejames/dappdefi" class="hover:text-accent">Contribute</a>
          <span class="mx-2">·</span>
          <a href="/rss.xml" class="hover:text-accent">RSS</a>
        </span>
      </div>
    </footer>
  </body>
</html>
