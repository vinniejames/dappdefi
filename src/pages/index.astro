---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import FeaturedRow from '../components/FeaturedRow.astro';
import ProtocolCard from '../components/ProtocolCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, CATEGORY_BY_SLUG } from '../data/categories';
import featured from '../data/featured.json';

const protocols = await getCollection('protocols');
const protoBySlug = new Map(protocols.map((p) => [p.slug, p]));

const cardData = (slug: string) => {
  const p = protoBySlug.get(slug);
  if (!p) return null;
  return {
    slug: p.slug,
    name: p.data.name,
    category: p.data.category,
    subcategories: p.data.subcategories,
    chains: p.data.chains,
    logo: p.data.logo,
  };
};

const recent = [...protocols]
  .sort((a, b) => +b.data.listed_at - +a.data.listed_at)
  .slice(0, 8)
  .map((p) => cardData(p.slug)!)
  .filter(Boolean);

type Card = NonNullable<ReturnType<typeof cardData>>;
const featuredMap = featured as Record<string, string[]>;
const featuredRows = CATEGORIES
  .filter((c) => c.slug !== 'other')
  .map((cat) => {
    const slugs = featuredMap[cat.slug] ?? [];
    const cards = slugs.map(cardData).filter(Boolean) as Card[];
    return { cat, cards };
  })
  .filter((row) => row.cards.length > 0);
---
<BaseLayout description="An open-source directory of 500+ DeFi protocols.">
  <section class="border-b border-ink-200 bg-gradient-to-b from-accent/5 to-transparent py-16 dark:border-ink-700 dark:from-accent/10">
    <div class="container-page">
      <h1 class="max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">
        Dapp DeFi — the open directory of DeFi protocols.
      </h1>
      <p class="mt-3 max-w-2xl text-lg text-ink-600 dark:text-ink-300">
        {protocols.length.toLocaleString()} protocols and counting, organized by what they actually do. Search, filter, and explore — markdown-powered, fully open-source.
      </p>
      <div class="mt-6 max-w-2xl">
        <SearchBar />
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="container-page">
      <h2 class="mb-5 text-xl font-semibold">Recently added</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {recent.map((p) => <ProtocolCard {...p} />)}
      </div>
    </div>
  </section>

  <div class="container-page">
    {featuredRows.map(({ cat, cards }) => (
      <FeaturedRow slug={cat.slug} name={cat.name} description={cat.description} protocols={cards} />
    ))}
  </div>
</BaseLayout>
