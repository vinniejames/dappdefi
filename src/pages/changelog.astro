---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagPill from '../components/TagPill.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_BY_SLUG } from '../data/categories';

// Build the changelog from each protocol's `listed_at` frontmatter,
// grouped by month descending. We deliberately do NOT walk `git log` —
// the listed_at field is the public-facing record of when something
// entered the directory.
const protocols = await getCollection('protocols');

type Entry = {
  slug: string;
  name: string;
  category: string;
  categoryName: string;
  excerpt: string;
  date: Date;
};

function excerpt(body: string | undefined): string {
  if (!body) return '';
  const text = body.replace(/[#*_`>\[\]]/g, '').replace(/\s+/g, ' ').trim();
  return text.length > 220 ? text.slice(0, 218) + '…' : text;
}

const entries: Entry[] = protocols
  .map((p) => ({
    slug: p.slug,
    name: p.data.name,
    category: p.data.category,
    categoryName: CATEGORY_BY_SLUG[p.data.category]?.name ?? p.data.category,
    excerpt: excerpt(p.body),
    date: p.data.listed_at,
  }))
  .sort((a, b) => +b.date - +a.date);

// Group by YYYY-MM
const monthFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', timeZone: 'UTC' });
const groups = new Map<string, { label: string; entries: Entry[] }>();
for (const e of entries) {
  const key = `${e.date.getUTCFullYear()}-${String(e.date.getUTCMonth() + 1).padStart(2, '0')}`;
  const label = monthFmt.format(e.date);
  if (!groups.has(key)) groups.set(key, { label, entries: [] });
  groups.get(key)!.entries.push(e);
}
const sortedGroups = [...groups.entries()].sort((a, b) => b[0].localeCompare(a[0]));

// Lightweight breadcrumb + WebPage JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://dappdefi.com/' },
    { '@type': 'ListItem', position: 2, name: 'Changelog', item: 'https://dappdefi.com/changelog/' },
  ],
};
---
<BaseLayout
  title="Changelog"
  description={`Every protocol added to the directory, ${entries.length} entries grouped by month.`}
  jsonLd={[breadcrumbLd]}
>
  <section class="border-b border-ink-200 py-10 dark:border-ink-700">
    <div class="container-page">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Changelog</h1>
      <p class="mt-2 max-w-2xl text-ink-600 dark:text-ink-300">
        Every protocol added to the directory, in reverse-chronological order. {entries.length} entries.
      </p>
      <p class="mt-3 text-sm text-ink-500 dark:text-ink-400">
        Subscribe via <a href="/rss.xml" class="text-accent hover:text-accent-hover">RSS</a>.
      </p>
    </div>
  </section>
  <section class="container-page py-10">
    {sortedGroups.map(([key, group]) => (
      <div class="mb-12">
        <h2 id={key} class="mb-6 text-xl font-semibold tracking-tight">
          {group.label}
          <span class="ml-2 text-sm font-normal text-ink-500 dark:text-ink-400">{group.entries.length}</span>
        </h2>
        <ul class="space-y-6">
          {group.entries.map((e) => (
            <li class="border-l-2 border-ink-200 pl-5 dark:border-ink-700">
              <div class="flex flex-wrap items-baseline gap-2">
                <a href={`/protocols/${e.slug}/`} class="text-lg font-semibold tracking-tight hover:text-accent">{e.name}</a>
                <a href={`/categories/${e.category}/`} class="pill-accent">{e.categoryName}</a>
                <time class="text-xs text-ink-500 dark:text-ink-400" datetime={e.date.toISOString()}>{e.date.toISOString().slice(0, 10)}</time>
              </div>
              {e.excerpt && (
                <p class="mt-2 text-sm leading-6 text-ink-600 dark:text-ink-300">{e.excerpt}</p>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>
