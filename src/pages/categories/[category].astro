---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Filters from '../../components/Filters.astro';
import TagPill from '../../components/TagPill.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, CATEGORY_BY_SLUG } from '../../data/categories';

export async function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { category: c.slug } }));
}

const { category } = Astro.params;
const cat = CATEGORY_BY_SLUG[category as keyof typeof CATEGORY_BY_SLUG];
const all = await getCollection('protocols');
const protocols = all
  .filter((p) => p.data.category === category)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const chainSet = new Set<string>();
const subSet = new Set<string>();
for (const p of protocols) {
  for (const c of p.data.chains) chainSet.add(c);
  for (const s of p.data.subcategories) subSet.add(s);
}
const chains = [...chainSet].sort();
const subcategories = [...subSet].sort();
---
<BaseLayout title={cat.name} description={cat.description}>
  <section class="border-b border-ink-200 py-10 dark:border-ink-700">
    <div class="container-page">
      <h1 class="text-3xl font-bold">{cat.name}</h1>
      <p class="mt-2 max-w-2xl text-ink-600 dark:text-ink-300">{cat.description}</p>
      <p class="mt-3 text-sm text-ink-500 dark:text-ink-400">{protocols.length} protocols</p>
    </div>
  </section>
  <section class="container-page py-8">
    {protocols.length > 0 ? (
      <>
        <Filters chains={chains} subcategories={subcategories} />
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {protocols.map((p) => (
            <a
              data-protocol
              data-chains={p.data.chains.join(',')}
              data-subcategories={p.data.subcategories.join(',')}
              data-maturity={p.data.tags.maturity ?? 'growing'}
              href={`/protocols/${p.slug}/`}
              class="group flex flex-col gap-3 rounded-lg border border-ink-200 bg-white p-4 !text-ink-900 transition hover:border-accent hover:!text-ink-900 hover:shadow-sm dark:border-ink-700 dark:bg-ink-800 dark:!text-ink-100"
            >
              <div class="flex items-center gap-3">
                {p.data.logo ? (
                  <img src={p.data.logo} alt={p.data.name} class="h-10 w-10 rounded-full bg-ink-100 object-cover dark:bg-ink-700" loading="lazy" onerror="this.style.display='none'" />
                ) : (
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-ink-100 text-sm font-semibold text-ink-500 dark:bg-ink-700">
                    {p.data.name.slice(0, 2).toUpperCase()}
                  </div>
                )}
                <div class="min-w-0">
                  <div class="truncate font-semibold group-hover:text-accent">{p.data.name}</div>
                  <div class="text-xs text-ink-500 dark:text-ink-400">{p.data.chains[0]}</div>
                </div>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {p.data.subcategories.slice(0, 3).map((s) => <TagPill variant="accent">{s}</TagPill>)}
              </div>
            </a>
          ))}
        </div>
      </>
    ) : (
      <p class="text-ink-500 dark:text-ink-400">
        No protocols in this category yet. Be the first to <a href="https://github.com/vinniejames/dappdefi" class="text-accent hover:text-accent-hover">contribute one</a>.
      </p>
    )}
  </section>
</BaseLayout>
